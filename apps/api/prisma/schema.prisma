generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformUser {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String               @unique
  displayName         String
  passwordHash        String?
  status              PlatformUserStatus   @default(PENDING_ACTIVATION)
  activatedAt         DateTime?            @db.Timestamp(6)
  disabledAt          DateTime?            @db.Timestamp(6)
  isDeleted           Boolean              @default(false)
  deletedAt           DateTime?            @db.Timestamp(6)
  createdAt           DateTime             @default(now()) @db.Timestamp(6)
  updatedAt           DateTime             @updatedAt @db.Timestamp(6)
  activationTokens    ActivationToken[]
  reviewerAssignments ReviewerAssignment[]
  roleAssignments     RoleAssignment[]
  sessions            AuthSession[]
  teamMemberships     TeamMembership[]
  createdLeads        Lead[]               @relation("LeadCreator")
  ownedLeads          Lead[]               @relation("LeadOwner")
  ownedActivities     Activity[]           @relation("ActivityOwner")
  recordedActivities  Activity[]           @relation("ActivityRecorder")
  ExhibitionAttendee  ExhibitionAttendee[]

  @@index([status])
  @@index([isDeleted])
  @@index([status, isDeleted])
  @@index([displayName])
  @@index([email])
}

model BusinessRole {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            BusinessRoleCode @unique
  name            String
  description     String
  isSystemManaged Boolean          @default(true)
  createdAt       DateTime         @default(now()) @db.Timestamp(6)
  assignments     RoleAssignment[]
}

model Permission {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String            @unique
  resource    String
  action      String
  description String
  createdAt   DateTime          @default(now()) @db.Timestamp(6)
  grants      PermissionGrant[]
}

model PermissionGrant {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  granteeType    GranteeType
  granteeCode    String
  permissionCode String
  createdAt      DateTime    @default(now()) @db.Timestamp(6)
  permission     Permission  @relation(fields: [permissionCode], references: [code], onDelete: Cascade, onUpdate: Cascade)

  @@unique([granteeType, granteeCode, permissionCode])
  @@index([granteeCode])
}

model RoleAssignment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String           @db.Uuid
  roleCode         BusinessRoleCode
  assignedByUserId String?          @db.Uuid
  assignedAt       DateTime         @default(now()) @db.Timestamp(6)
  removedByUserId  String?          @db.Uuid
  removedAt        DateTime?        @db.Timestamp(6)
  status           AssignmentStatus @default(ACTIVE)
  role             BusinessRole     @relation(fields: [roleCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  user             PlatformUser     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, status])
  @@index([roleCode, status])
}

model ReviewerAssignment {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String           @db.Uuid
  assignedByUserId String?          @db.Uuid
  assignedAt       DateTime         @default(now()) @db.Timestamp(6)
  removedByUserId  String?          @db.Uuid
  removedAt        DateTime?        @db.Timestamp(6)
  status           AssignmentStatus @default(ACTIVE)
  user             PlatformUser     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, status])
}

model Team {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  status             TeamStatus           @default(ACTIVE)
  createdByUserId    String?              @db.Uuid
  createdAt          DateTime             @default(now()) @db.Timestamp(6)
  updatedAt          DateTime             @updatedAt @db.Timestamp(6)
  deactivatedAt      DateTime?            @db.Timestamp(6)
  memberships        TeamMembership[]
  leads              Lead[]
  Activity           Activity[]
  ExhibitionAttendee ExhibitionAttendee[]

  @@index([name])
  @@index([status])
}

model TeamMembership {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String               @db.Uuid
  teamId           String               @db.Uuid
  membershipType   TeamMembershipType
  status           TeamMembershipStatus @default(ACTIVE)
  assignedByUserId String?              @db.Uuid
  assignedAt       DateTime             @default(now()) @db.Timestamp(6)
  endedByUserId    String?              @db.Uuid
  endedAt          DateTime?            @db.Timestamp(6)
  team             Team                 @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user             PlatformUser         @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([teamId, status])
  @@index([userId, status])
}

model ActivationToken {
  id              String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String                @db.Uuid
  tokenHash       String                @unique
  status          ActivationTokenStatus @default(ACTIVE)
  expiresAt       DateTime              @db.Timestamp(6)
  usedAt          DateTime?             @db.Timestamp(6)
  revokedAt       DateTime?             @db.Timestamp(6)
  createdByUserId String?               @db.Uuid
  createdAt       DateTime              @default(now()) @db.Timestamp(6)
  user            PlatformUser          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, status])
  @@index([expiresAt])
}

model AuthSession {
  id               String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String                       @db.Uuid
  sessionHash      String                       @unique
  status           AuthSessionStatus            @default(ACTIVE)
  issuedAt         DateTime                     @default(now()) @db.Timestamp(6)
  expiresAt        DateTime                     @db.Timestamp(6)
  revokedAt        DateTime?                    @db.Timestamp(6)
  revocationReason AuthSessionRevocationReason?
  lastSeenAt       DateTime?                    @db.Timestamp(6)
  user             PlatformUser                 @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId, status])
}

model AccessDecision {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?             @db.Uuid
  permissionCode String
  resource       String
  action         String
  decision       AccessDecisionValue
  reason         String
  correlationId  String
  decidedAt      DateTime            @default(now()) @db.Timestamp(6)

  @@index([correlationId])
  @@index([permissionCode, decision])
}

model SecurityAuditRecord {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType     String
  actorUserId   String?              @db.Uuid
  targetUserId  String?              @db.Uuid
  sessionId     String?              @db.Uuid
  resource      String?
  outcome       SecurityAuditOutcome
  ipAddress     String?
  userAgent     String?
  correlationId String
  metadata      Json                 @default("{}")
  createdAt     DateTime             @default(now()) @db.Timestamp(6)

  @@index([actorUserId])
  @@index([targetUserId])
  @@index([eventType, outcome, createdAt])
  @@index([correlationId])
}

model OperationalEvent {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  version        Int                    @default(1)
  payload        Json                   @default("{}")
  idempotencyKey String                 @unique
  correlationId  String
  status         OperationalEventStatus @default(RECORDED)
  createdAt      DateTime               @default(now()) @db.Timestamp(6)
  handledAt      DateTime?              @db.Timestamp(6)
  jobs           BackgroundJob[]

  @@index([correlationId])
  @@index([status])
}

model BackgroundJob {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operationalEventId String?             @db.Uuid
  queueName          String
  jobType            String
  status             BackgroundJobStatus @default(QUEUED)
  attempts           Int                 @default(0)
  maxAttempts        Int
  idempotencyKey     String              @unique
  correlationId      String
  lastError          String?
  createdAt          DateTime            @default(now()) @db.Timestamp(6)
  startedAt          DateTime?           @db.Timestamp(6)
  completedAt        DateTime?           @db.Timestamp(6)
  event              OperationalEvent?   @relation(fields: [operationalEventId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([status])
  @@index([correlationId])
}

model LeadSource {
  id        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code      String           @unique
  name      String
  status    LeadSourceStatus @default(ACTIVE)
  createdAt DateTime         @default(now()) @db.Timestamp(6)
  updatedAt DateTime         @updatedAt @db.Timestamp(6)
  leads     Lead[]

  @@index([status])
}

model Lead {
  id                     String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  displayName            String
  company                String?
  email                  String?
  normalizedEmail        String?
  phone                  String?
  normalizedPhone        String?
  sourceCode             String
  status                 LeadStatus                  @default(NEW)
  priority               LeadPriority
  budgetAmount           Decimal?                    @db.Decimal(14, 2)
  budgetCurrency         String?
  ownerUserId            String                      @db.Uuid
  teamId                 String?                     @db.Uuid
  createdByUserId        String                      @db.Uuid
  version                Int                         @default(1)
  createdAt              DateTime                    @default(now()) @db.Timestamp(6)
  updatedAt              DateTime                    @updatedAt @db.Timestamp(6)
  archivedAt             DateTime?                   @db.Timestamp(6)
  source                 LeadSource                  @relation(fields: [sourceCode], references: [code], onDelete: Restrict, onUpdate: Cascade)
  owner                  PlatformUser                @relation("LeadOwner", fields: [ownerUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  creator                PlatformUser                @relation("LeadCreator", fields: [createdByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  team                   Team?                       @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  exhibitionReference    LeadExhibitionReference?
  activities             Activity[]
  assignments            LeadAssignment[]
  statusHistory          LeadStatusHistory[]
  notes                  LeadNote[]
  historyEntries         LeadHistoryEntry[]
  accessDecisions        LeadAccessDecision[]
  exhibitionAttributions ExhibitionLeadAttribution[]
  domainEvents           LeadDomainEvent[]

  @@index([status])
  @@index([sourceCode])
  @@index([priority])
  @@index([ownerUserId])
  @@index([teamId])
  @@index([createdByUserId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([displayName])
  @@index([company])
  @@index([normalizedEmail])
  @@index([normalizedPhone])
  @@index([version])
}

model LeadExhibitionReference {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId          String    @unique @db.Uuid
  name            String
  date            DateTime? @db.Date
  location        String?
  createdByUserId String?   @db.Uuid
  updatedByUserId String?   @db.Uuid
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  lead            Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([name])
  @@index([date])
}

model LeadAssignment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId           String   @db.Uuid
  fromUserId       String?  @db.Uuid
  toUserId         String   @db.Uuid
  fromTeamId       String?  @db.Uuid
  toTeamId         String?  @db.Uuid
  assignedByUserId String   @db.Uuid
  reason           String?
  createdAt        DateTime @default(now()) @db.Timestamp(6)
  correlationId    String
  lead             Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([leadId])
  @@index([toUserId])
  @@index([toTeamId])
  @@index([createdAt])
  @@index([correlationId])
}

model LeadStatusHistory {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId          String               @db.Uuid
  fromStatus      LeadStatus?
  toStatus        LeadStatus
  changedByUserId String               @db.Uuid
  changeType      LeadStatusChangeType
  reason          String?
  createdAt       DateTime             @default(now()) @db.Timestamp(6)
  correlationId   String
  lead            Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([leadId])
  @@index([toStatus])
  @@index([createdAt])
  @@index([correlationId])
}

model LeadNote {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId        String   @db.Uuid
  authorUserId  String   @db.Uuid
  body          String
  createdAt     DateTime @default(now()) @db.Timestamp(6)
  correlationId String
  lead          Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([leadId])
  @@index([authorUserId])
  @@index([createdAt])
  @@index([correlationId])
}

model LeadHistoryEntry {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId        String               @db.Uuid
  entryType     LeadHistoryEntryType
  actorUserId   String?              @db.Uuid
  summary       String
  metadata      Json                 @default("{}")
  createdAt     DateTime             @default(now()) @db.Timestamp(6)
  correlationId String
  lead          Lead                 @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([leadId])
  @@index([entryType])
  @@index([actorUserId])
  @@index([createdAt])
  @@index([correlationId])
}

model LeadAccessDecision {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?             @db.Uuid
  leadId        String?             @db.Uuid
  action        LeadAction
  decision      AccessDecisionValue
  reason        String
  scope         LeadAccessScope
  createdAt     DateTime            @default(now()) @db.Timestamp(6)
  correlationId String
  lead          Lead?               @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([userId])
  @@index([leadId])
  @@index([action])
  @@index([decision])
  @@index([createdAt])
  @@index([correlationId])
}

model LeadDomainEvent {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           LeadDomainEventName
  version        Int                    @default(1)
  leadId         String                 @db.Uuid
  payload        Json                   @default("{}")
  idempotencyKey String                 @unique
  correlationId  String
  status         OperationalEventStatus @default(RECORDED)
  createdAt      DateTime               @default(now()) @db.Timestamp(6)
  handledAt      DateTime?              @db.Timestamp(6)
  lead           Lead                   @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([leadId])
  @@index([name])
  @@index([status])
  @@index([createdAt])
  @@index([correlationId])
}

model Activity {
  id                 String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId             String           @db.Uuid
  type               ActivityType
  status             ActivityStatus   @default(PLANNED)
  ownerUserId        String           @db.Uuid
  teamId             String?          @db.Uuid
  recordedByUserId   String           @db.Uuid
  activityAt         DateTime?        @db.Timestamp(6)
  dueAt              DateTime?        @db.Timestamp(6)
  completedAt        DateTime?        @db.Timestamp(6)
  canceledAt         DateTime?        @db.Timestamp(6)
  outcome            ActivityOutcome?
  note               String?
  cancellationReason String?
  version            Int              @default(1)
  correlationId      String
  createdAt          DateTime         @default(now()) @db.Timestamp(6)
  updatedAt          DateTime         @updatedAt @db.Timestamp(6)
  lead               Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  owner              PlatformUser     @relation("ActivityOwner", fields: [ownerUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  recorder           PlatformUser     @relation("ActivityRecorder", fields: [recordedByUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  team               Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([leadId, activityAt, dueAt, createdAt])
  @@index([ownerUserId, status, dueAt])
  @@index([teamId, status, dueAt])
  @@index([type, status, createdAt])
  @@index([correlationId])
  @@index([version])
}

model ActivityAuditEntry {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  activityId    String?              @db.Uuid
  leadId        String?              @db.Uuid
  actorUserId   String?              @db.Uuid
  eventType     ActivityAuditType
  outcome       SecurityAuditOutcome @default(SUCCESS)
  metadata      Json                 @default("{}")
  correlationId String
  createdAt     DateTime             @default(now()) @db.Timestamp(6)

  @@index([activityId, createdAt])
  @@index([leadId, createdAt])
  @@index([actorUserId])
  @@index([eventType, outcome, createdAt])
  @@index([correlationId])
}

model Exhibition {
  id              String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  startsAt        DateTime                    @db.Timestamp(6)
  endsAt          DateTime                    @db.Timestamp(6)
  location        String
  status          ExhibitionStatus            @default(PLANNED)
  ownerUserId     String                      @db.Uuid
  teamId          String?                     @db.Uuid
  notes           String?
  archiveReason   String?
  version         Int                         @default(1)
  createdByUserId String                      @db.Uuid
  updatedByUserId String                      @db.Uuid
  createdAt       DateTime                    @default(now()) @db.Timestamp(6)
  updatedAt       DateTime                    @updatedAt @db.Timestamp(6)
  archivedAt      DateTime?                   @db.Timestamp(6)
  correlationId   String
  attendees       ExhibitionAttendee[]
  attributions    ExhibitionLeadAttribution[]
  historyEntries  ExhibitionHistoryEntry[]

  @@index([status])
  @@index([teamId])
  @@index([ownerUserId])
  @@index([startsAt, endsAt])
  @@index([version])
  @@index([correlationId])
}

model ExhibitionAttendee {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exhibitionId      String         @db.Uuid
  userId            String         @db.Uuid
  teamId            String?        @db.Uuid
  plannedRole       String?
  status            AttendeeStatus @default(PLANNED)
  confirmedAt       DateTime?      @db.Timestamp(6)
  confirmedByUserId String?        @db.Uuid
  assignedByUserId  String         @db.Uuid
  removedByUserId   String?        @db.Uuid
  correctionReason  String?
  version           Int            @default(1)
  createdAt         DateTime       @default(now()) @db.Timestamp(6)
  updatedAt         DateTime       @updatedAt @db.Timestamp(6)
  correlationId     String
  exhibition        Exhibition     @relation(fields: [exhibitionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user              PlatformUser   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  team              Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([exhibitionId, userId])
  @@index([exhibitionId, status, createdAt])
  @@index([userId, status])
  @@index([teamId])
  @@index([correlationId])
}

model ExhibitionLeadAttribution {
  id                      String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exhibitionId            String            @db.Uuid
  leadId                  String            @db.Uuid
  attributionType         AttributionType
  status                  AttributionStatus @default(ACTIVE)
  sourceReferenceName     String?
  sourceReferenceDate     DateTime?         @db.Date
  sourceReferenceLocation String?
  createdByUserId         String            @db.Uuid
  updatedByUserId         String?           @db.Uuid
  correctionReason        String?
  version                 Int               @default(1)
  createdAt               DateTime          @default(now()) @db.Timestamp(6)
  updatedAt               DateTime          @updatedAt @db.Timestamp(6)
  correlationId           String
  exhibition              Exhibition        @relation(fields: [exhibitionId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  lead                    Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([exhibitionId, leadId, status, createdAt])
  @@index([leadId])
  @@index([correlationId])
}

model ExhibitionHistoryEntry {
  id             String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  exhibitionId   String                     @db.Uuid
  entryType      ExhibitionHistoryEntryType
  actorUserId    String?                    @db.Uuid
  leadId         String?                    @db.Uuid
  attendeeUserId String?                    @db.Uuid
  summary        String
  metadata       Json                       @default("{}")
  createdAt      DateTime                   @default(now()) @db.Timestamp(6)
  correlationId  String
  exhibition     Exhibition                 @relation(fields: [exhibitionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([exhibitionId])
  @@index([entryType])
  @@index([actorUserId])
  @@index([leadId])
  @@index([attendeeUserId])
  @@index([createdAt])
  @@index([correlationId])
}

model ExhibitionAccessDecision {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String?               @db.Uuid
  exhibitionId  String?               @db.Uuid
  leadId        String?               @db.Uuid
  action        ExhibitionAction
  decision      AccessDecisionValue
  reason        String
  scope         ExhibitionAccessScope
  createdAt     DateTime              @default(now()) @db.Timestamp(6)
  correlationId String

  @@index([userId])
  @@index([exhibitionId])
  @@index([leadId])
  @@index([action])
  @@index([decision])
  @@index([createdAt])
  @@index([correlationId])
}

model ExhibitionDomainEvent {
  id             String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           ExhibitionDomainEventName
  version        Int                       @default(1)
  exhibitionId   String                    @db.Uuid
  leadId         String?                   @db.Uuid
  attendeeUserId String?                   @db.Uuid
  payload        Json                      @default("{}")
  idempotencyKey String                    @unique
  correlationId  String
  status         OperationalEventStatus    @default(RECORDED)
  createdAt      DateTime                  @default(now()) @db.Timestamp(6)
  handledAt      DateTime?                 @db.Timestamp(6)

  @@index([exhibitionId])
  @@index([leadId])
  @@index([attendeeUserId])
  @@index([name])
  @@index([status])
  @@index([createdAt])
  @@index([correlationId])
}

enum PlatformUserStatus {
  PENDING_ACTIVATION
  ACTIVE
  DISABLED
}

enum BusinessRoleCode {
  ADMIN
  MANAGER
  SALES_REPRESENTATIVE
}

enum GranteeType {
  BUSINESS_ROLE
  ACCESS_PROFILE
}

enum AssignmentStatus {
  ACTIVE
  REMOVED
}

enum TeamStatus {
  ACTIVE
  INACTIVE
}

enum TeamMembershipType {
  MEMBER
  MANAGER
}

enum TeamMembershipStatus {
  ACTIVE
  ENDED
}

enum ActivationTokenStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

enum AuthSessionStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuthSessionRevocationReason {
  LOGOUT
  USER_DISABLED
  ROLE_REMOVED
  REVIEWER_ACCESS_REMOVED
  SECURITY_REVOKE
  USER_DELETED
}

enum AccessDecisionValue {
  ALLOW
  DENY
}

enum SecurityAuditOutcome {
  SUCCESS
  FAILURE
  DENIED
}

enum OperationalEventStatus {
  RECORDED
  DISPATCHED
  HANDLED
  FAILED
}

enum BackgroundJobStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
}

enum LeadSourceStatus {
  ACTIVE
  INACTIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NEGOTIATION
  WON
  LOST
  ARCHIVED
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum LeadStatusChangeType {
  NORMAL_FLOW
  CORRECTION
  ARCHIVE
  RESTORE
}

enum LeadHistoryEntryType {
  CREATED
  CONTACT_UPDATED
  ASSIGNED
  STATUS_CHANGED
  STATUS_CORRECTED
  ARCHIVED
  RESTORED
  SOURCE_CHANGED
  EXHIBITION_REFERENCE_CHANGED
  NOTE_ADDED
  DUPLICATE_BLOCKED
  STALE_UPDATE_REJECTED
  ACTIVITY_CREATED
  FOLLOW_UP_SCHEDULED
  FOLLOW_UP_COMPLETED
  FOLLOW_UP_REASSIGNED
  ACTIVITY_CANCELED
  ACTIVITY_CORRECTED
  FOLLOW_UP_STATUS_CHANGED
}

enum LeadAction {
  CREATE
  VIEW
  UPDATE
  ASSIGN
  CHANGE_STATUS
  ADD_NOTE
  VIEW_HISTORY
  SEARCH
  ACTIVITY_CREATE
  ACTIVITY_VIEW
  ACTIVITY_COMPLETE
  ACTIVITY_REASSIGN
  ACTIVITY_CANCEL
  ACTIVITY_SEARCH
